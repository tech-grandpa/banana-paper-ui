# PaperBanana Environment Variables
# Copy this file to .env and fill in your keys.

# Google Gemini (free, no credit card): https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# OpenRouter (optional, for alternative models): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Provider Selection ─────────────────────────────────────────────
# Default: Google Gemini for both VLM and image generation
# To use OpenRouter instead, uncomment and configure:
# VLM_PROVIDER=openrouter
# VLM_MODEL=anthropic/claude-sonnet-4-20250514
# IMAGE_PROVIDER=openrouter_imagen
# IMAGE_MODEL=google/gemini-3-pro-image-preview

# ── SSL ────────────────────────────────────────────────────────────
# Set to true to skip SSL certificate verification (corporate proxies)
SKIP_SSL_VERIFICATION=false
