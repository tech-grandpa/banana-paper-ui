# PaperBanana Environment Variables
# Copy this file to .env and fill in your keys.

# OpenAI (alternative): https://platform.openai.com/api-keys
# To use OpenAI instead of Gemini, uncomment these:
# VLM_PROVIDER=openai
# IMAGE_PROVIDER=openai_imagen
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VLM_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
# For gpt-image-2, use 4k/high for final assets or 2k/auto for faster iteration.
# OUTPUT_RESOLUTION=4k
# IMAGE_QUALITY=high
# For Azure OpenAI / Foundry, point to your endpoint:
#   OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1

# Atlas Cloud (OpenAI-compatible chat + Atlas image generation)
# Docs: https://www.atlascloud.ai/docs
# VLM_PROVIDER=atlas
# IMAGE_PROVIDER=atlas_imagen
ATLASCLOUD_API_KEY=
ATLASCLOUD_BASE_URL=https://api.atlascloud.ai/v1
# Default validated Atlas chat model from the rollout pool.
ATLASCLOUD_VLM_MODEL=deepseek-ai/DeepSeek-V3-0324
ATLASCLOUD_IMAGE_BASE_URL=https://api.atlascloud.ai/api/v1
# Recommended Atlas image default for PaperBanana.
ATLASCLOUD_IMAGE_MODEL=openai/gpt-image-2/text-to-image

# OpenRouter (used by the hosted web app): https://openrouter.ai/keys
# VLM_PROVIDER=openrouter
# VLM_MODEL=anthropic/claude-opus-4.8
# IMAGE_PROVIDER=openrouter_imagen
# IMAGE_MODEL=google/gemini-3-pro-image
OPENROUTER_API_KEY=

# Hosted FastAPI safety limits (conservative defaults shown)
# One Uvicorn worker is required for process-wide in-memory limits.
WEB_MAX_TEXT_CHARS=40000
WEB_MAX_CAPTION_CHARS=2000
# Reject request bodies above 256 KiB before JSON parsing.
WEB_MAX_REQUEST_BYTES=262144
WEB_MAX_ACTIVE_JOBS=1
WEB_MAX_GLOBAL_REQUESTS_PER_HOUR=4
WEB_MAX_CLIENT_REQUESTS_PER_HOUR=2
WEB_MAX_STORED_JOBS=100
WEB_JOB_BUDGET_USD=1.00
# Web generations use a dedicated root so retention never removes CLI runs.
WEB_RUNS_DIR=outputs/web
# Delete run directories (including prompts, source input, and images) after 24 hours.
WEB_RUN_TTL_SECONDS=86400
# Cap all retained web run files at 1 GiB; oldest completed runs are deleted first.
WEB_RUN_DISK_QUOTA_BYTES=1073741824
# Run retention once at startup and then every 5 minutes.
WEB_RUN_CLEANUP_INTERVAL_SECONDS=300
# Enable only when requests arrive through a trusted reverse proxy (for example Cloudflare).
WEB_TRUST_PROXY_HEADERS=false

# Google Gemini (free, no credit card): https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_VLM_MODEL=gemini-2.5-flash
GOOGLE_IMAGE_MODEL=gemini-3-pro-image-preview

# ── Local open-weight models ──────────────────────────────────────
# VLM_PROVIDER=ollama (requires: ollama pull <vision-model>)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-vl
# OLLAMA_JSON_MODE=false
#
# VLM_PROVIDER=openai_local (vLLM / llama.cpp)
# OPENAI_LOCAL_BASE_URL=http://localhost:8000/v1
# OPENAI_LOCAL_JSON_MODE=false

# ── SSL ────────────────────────────────────────────────────────────
# Set to true to skip SSL certificate verification (corporate proxies)
SKIP_SSL_VERIFICATION=false
